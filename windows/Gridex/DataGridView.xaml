<UserControl
    x:Class="Gridex.DataGridView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Gridex"
>
    <!-- Cell styles cached once, applied per-cell as a single Style property
         set instead of 4-5 individual property crossings. This is the bulk
         of the BuildRows() perf win for wide tables. -->
    <UserControl.Resources>
        <Style x:Key="GridCellStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="GridRowNumStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Padding" Value="4,0,4,0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Opacity" Value="0.4" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Column headers (synced scroll with data) -->
        <ScrollViewer Grid.Row="0" x:Name="HeaderScroller"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled">
            <StackPanel x:Name="HeaderRow" Orientation="Horizontal"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1" />
        </ScrollViewer>

        <!-- Data rows with virtual scrolling -->
        <ScrollViewer Grid.Row="1" x:Name="DataScroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
>
            <StackPanel x:Name="DataRows" Spacing="0" />
        </ScrollViewer>
    </Grid>
</UserControl>
